# Whale Watcher environment variables.
# Copy this file to .dev.vars for local development with `wrangler dev`.
# Production secrets are set with `wrangler secret put`, never committed.

# Shared secret used to authenticate API calls to /api/* routes that mutate
# state or return cross-user data. Accepted as either the X-API-Key header or
# the ?key= query string parameter.
AGENT_API_KEY=replace_me

# Resend API key. Get one from https://resend.com after verifying your sending domain.
RESEND_API_KEY=re_replace_me

# Brave Search API key. Free tier is 1 req/sec, 2000 requests/month.
# https://brave.com/search/api/
BRAVE_API_KEY=BSA_replace_me

# Finnhub API key for the public market dashboard at /. Optional.
# https://finnhub.io
FINNHUB_API_KEY=replace_me

# Resend webhook signing secret. Set this if you configure a webhook in the
# Resend dashboard pointing at /api/webhooks/resend.
RESEND_WEBHOOK_SECRET=whsec_replace_me
